rules_version = '2';

// Security rules — multi-tenant (per-company) isolation.
//
// Identity (custom claims):
//   * role         — "admin" | "field" | "telemarketing" | "group_leader" | "division_head"
//   * tenantId     — the company the user belongs to
//   * isSuperAdmin — platform owner; may access ANY company
//
// Every tenant-scoped document carries a tenantId. A normal user may only
// touch documents whose tenantId equals their own; a super admin may touch any.
// (Company "freeze" is enforced at the app + Auth level, not here, to avoid
// per-document get() calls that would exceed query rule limits.)

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn()  { return request.auth != null; }
    function myTenant()    { return request.auth.token.tenantId; }
    function isSuperAdmin(){ return isSignedIn() && request.auth.token.isSuperAdmin == true; }
    function isAdmin()     { return isSignedIn() && request.auth.token.role == 'admin'; }

    // Tenant-scoped access helpers.
    function canRead()   { return isSignedIn() && (isSuperAdmin() || resource.data.tenantId == myTenant()); }
    function canCreate() { return isSignedIn() && (isSuperAdmin() || request.resource.data.tenantId == myTenant()); }
    function canUpdate() { return isSignedIn() && (isSuperAdmin() || (resource.data.tenantId == myTenant() && request.resource.data.tenantId == myTenant())); }
    function canDelete() { return isSignedIn() && (isSuperAdmin() || resource.data.tenantId == myTenant()); }

    // ---- tenants (companies): read your own (or any, for super admin); only super admin writes ----
    match /tenants/{id} {
      allow read:  if isSignedIn() && (id == myTenant() || isSuperAdmin());
      allow write: if isSuperAdmin();
    }

    // ---- shared campaign data — tenant-scoped ----
    match /voters/{id}           { allow read: if canRead(); allow create: if canCreate(); allow update: if canUpdate(); allow delete: if canDelete(); }
    match /groups/{id}           { allow read: if canRead(); allow create: if canCreate(); allow update: if canUpdate(); allow delete: if canDelete(); }
    match /subGroups/{id}        { allow read: if canRead(); allow create: if canCreate(); allow update: if canUpdate(); allow delete: if canDelete(); }
    match /groupLeaders/{id}     { allow read: if canRead(); allow create: if canCreate(); allow update: if canUpdate(); allow delete: if canDelete(); }
    match /divisionHeads/{id}    { allow read: if canRead(); allow create: if canCreate(); allow update: if canUpdate(); allow delete: if canDelete(); }
    match /listManagers/{id}     { allow read: if canRead(); allow create: if canCreate(); allow update: if canUpdate(); allow delete: if canDelete(); }
    match /lists/{id}            { allow read: if canRead(); allow create: if canCreate(); allow update: if canUpdate(); allow delete: if canDelete(); }
    match /statuses/{id}         { allow read: if canRead(); allow create: if canCreate(); allow update: if canUpdate(); allow delete: if canDelete(); }
    match /callStatuses/{id}     { allow read: if canRead(); allow create: if canCreate(); allow update: if canUpdate(); allow delete: if canDelete(); }
    match /conversationLogs/{id} { allow read: if canRead(); allow create: if canCreate(); allow update: if canUpdate(); allow delete: if canDelete(); }
    match /reminders/{id}        { allow read: if canRead(); allow create: if canCreate(); allow update: if canUpdate(); allow delete: if canDelete(); }

    // ---- users — read within company; writes by admins (within company) or super admin ----
    match /users/{id} {
      allow read:   if canRead();
      allow create: if (isAdmin() || isSuperAdmin()) && canCreate();
      // Admins update any user in their company; super admin updates anyone.
      // Additionally, ANY user may update ONLY their own profile photo
      // (photoURL) — nothing else (role, tenantId, isFrozen, etc. stay locked).
      allow update: if ((isAdmin() || isSuperAdmin()) && canUpdate())
        || (isSignedIn() && request.auth.uid == id
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['photoURL']));
      allow delete: if (isAdmin() || isSuperAdmin()) && canDelete();
    }

    // ---- callShares — identity-gated links to a single call summary ----
    // Read: only the chosen recipient, the sharer, or a company admin / super.
    // Create: admins or telemarketing reps, within their own company.
    // Delete (revoke): the sharer or a company admin / super. No updates.
    match /callShares/{id} {
      allow read: if isSignedIn() && (isSuperAdmin() ||
        (resource.data.tenantId == myTenant() &&
          (request.auth.uid == resource.data.sharedWithUserId
            || request.auth.uid == resource.data.sharedById
            || isAdmin())));
      allow create: if isSignedIn() && request.resource.data.tenantId == myTenant()
        && (isAdmin() || request.auth.token.role == 'telemarketing');
      allow delete: if isSignedIn() && (isSuperAdmin() ||
        (resource.data.tenantId == myTenant() &&
          (request.auth.uid == resource.data.sharedById || isAdmin())));
    }

    // ---- passwordResets — server only (Admin SDK bypasses rules) ----
    match /passwordResets/{id} { allow read, write: if false; }

    // ---- everything else — deny ----
    match /{document=**} { allow read, write: if false; }
  }
}
