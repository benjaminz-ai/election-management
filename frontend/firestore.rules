rules_version = '2';

// Security rules for the election-management app.
//
// Model:
//   * Every staff member now authenticates through Firebase Authentication.
//   * Their role is stored as a custom claim (request.auth.token.role):
//     "admin" | "field" | "telemarketing" | "group_leader" | "division_head".
//   * Shared campaign data is loaded/edited client-side by any signed-in
//     staff member, so those collections require authentication (not anonymous).
//   * User management is admin-only.
//   * passwordResets is written ONLY by the server (Admin SDK), which bypasses
//     these rules — so all client access is denied.
//
// This replaces the temporary open rule (allow ... if true) that was the
// original security hole.

service cloud.firestore {
  match /databases/{database}/documents {

    // ---- helpers ----
    function isSignedIn() {
      return request.auth != null;
    }
    function isAdmin() {
      return isSignedIn() && request.auth.token.role == 'admin';
    }

    // ---- shared campaign data: any signed-in staff member ----
    match /voters/{id}        { allow read, write: if isSignedIn(); }
    match /groups/{id}        { allow read, write: if isSignedIn(); }
    match /subGroups/{id}     { allow read, write: if isSignedIn(); }
    match /groupLeaders/{id}  { allow read, write: if isSignedIn(); }
    match /divisionHeads/{id} { allow read, write: if isSignedIn(); }
    match /statuses/{id}      { allow read, write: if isSignedIn(); }
    match /callStatuses/{id}  { allow read, write: if isSignedIn(); }
    match /conversationLogs/{id} { allow read, write: if isSignedIn(); }

    // ---- reminders: personal, any signed-in user manages them ----
    match /reminders/{id}     { allow read, write: if isSignedIn(); }

    // ---- users: everyone signed-in may read the roster; only admins write ----
    match /users/{id} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }

    // ---- passwordResets: server-only (Admin SDK bypasses rules) ----
    match /passwordResets/{id} {
      allow read, write: if false;
    }

    // ---- everything else: deny ----
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
